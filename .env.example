# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google AdSense (Client-side variables must start with VITE_ to be exposed to Vite)
# VITE_ADSENSE_CLIENT_ID: Your Google AdSense Publisher ID (e.g., ca-pub-XXXXXXXXXXXXXXXX)
# VITE_ADSENSE_TOP_SLOT_ID: Your AdSense Ad Slot ID for the top ad unit (e.g., YYYYYYYYYY)
# VITE_ADSENSE_BOTTOM_SLOT_ID: Your AdSense Ad Slot ID for the bottom ad unit (e.g., ZZZZZZZZZZ)
# VITE_ADSENSE_CLIENT_ID=
# VITE_ADSENSE_TOP_SLOT_ID=
# VITE_ADSENSE_BOTTOM_SLOT_ID=
